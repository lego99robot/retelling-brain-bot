{
  "name": "retelling-brain-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2026-06-13",
    "db:migrate:local": "wrangler d1 migrations apply retelling_brain_bot --local",
    "db:migrate:remote": "wrangler d1 migrations apply retelling_brain_bot --remote"
  },
  "dependencies": {
    "@upstash/vector": "^1.2.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wrangler": "^4.20.0"
  }
}
